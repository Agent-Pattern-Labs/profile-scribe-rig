{
  "profileScribe": {
    "root": "",
    "apiUrl": "",
    "apiTokenEnv": "PROFILE_SCRIBE_API_TOKEN",
    "submitMode": "draft"
  },
  "crawler": {
    "timeoutMs": 20000,
    "maxBytes": 2000000,
    "userAgent": "profile-scribe-agent-harness"
