{
  "profileScribe": {
    "root": "",
    "apiUrl": "",
    "mcpCommand": "profilescribe-mcp",
    "mcpUrl": "https://profilescribe.com/api/mcp",
    "apiTokenEnv": "PROFILE_SCRIBE_API_TOKEN",
    "agentTokenEnv": "PROFILESCRIBE_AGENT_TOKEN",
    "submitMode": "draft"
  },
  "crawler": {
    "timeoutMs": 20000,
    "maxBytes": 2000000,
    "userAgent": "profile-scribe-rig"
  },
  "retrieval": {
    "priorPostLimit": 100,
    "relatedPostLimit": 12
  },
  "posting": {
    "defaultVisibility": "draft",
    "requireReview": true
  }
}
