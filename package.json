{
  "name": "@agent-pattern-labs/profile-scribe-rig",
  "version": "0.1.9",
  "description": "Agentic harness for crawling sources, matching user voice, and drafting Profile Scribe posts.",
  "type": "module",
  "bin": {
    "profile-scribe-harness": "bin/profile-scribe-harness.mjs",
    "create-profile-scribe-harness": "bin/create-profile-scribe-harness.mjs"
  },
  "scripts": {
    "sync": "node bin/sync.mjs",
    "verify": "npm run smoke:config && npm run smoke:source-ids && npm run smoke:topic-guard && npm run smoke:quality-gate && npm run smoke:openrouter-usage && npm run smoke:timeline-brief && npm run smoke:source-opportunities && npm run smoke:evidence-opportunities",
    "smoke:config": "node scripts/smoke-config.mjs",
    "smoke:source-ids": "node scripts/smoke-run-job-source-ids.mjs",
    "smoke:topic-guard": "node scripts/smoke-run-job-topic-guard.mjs",
    "smoke:quality-gate": "node scripts/smoke-run-job-quality-gate.mjs",
    "smoke:openrouter-usage": "node scripts/smoke-run-job-openrouter-usage.mjs",
    "smoke:timeline-brief": "node scripts/smoke-run-job-timeline-brief.mjs",
    "smoke:source-opportunities": "node scripts/smoke-run-job-source-opportunities.mjs",
    "smoke:evidence-opportunities": "node scripts/smoke-run-job-evidence-opportunities.mjs",
    "plan": "iso plan .",
    "build:config": "iso build .",
    "lint:agentmd": "agentmd lint iso/instructions.md",
    "postinstall": "node bin/sync.mjs",
    "prepack": "npm run smoke:config"
  },
  "files": [
    "Agents.md",
    "README.md",
    "bin/",
    "iso/",
    "modes/",
    "templates/",
    "config/",
    "scripts/",
    "docs/",
    "batch/",
    "models.yaml"
  ],
  "keywords": [
    "agentic-harness",
    "profile-scribe",
    "content",
    "voice-matching",
    "automation"
  ],
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/Agent-Pattern-Labs/profile-scribe-rig.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20.6.0"
  },
  "overrides": {
    "fast-uri": "3.1.2"
  },
  "dependencies": {
    "@agent-pattern-labs/iso-cache": "^0.1.1",
    "@agent-pattern-labs/iso-canon": "^0.1.1",
    "@agent-pattern-labs/iso-context": "^0.1.1",
    "@agent-pattern-labs/iso-contract": "^0.1.1",
    "@agent-pattern-labs/iso-facts": "^0.1.1",
    "@agent-pattern-labs/iso-index": "^0.1.1",
    "@agent-pattern-labs/iso-ledger": "^0.1.1",
    "@agent-pattern-labs/iso-lineage": "^0.1.1",
    "@agent-pattern-labs/iso-migrate": "^0.1.1",
    "@agent-pattern-labs/iso-postflight": "^0.1.1",
    "@agent-pattern-labs/iso-preflight": "^0.1.1",
    "@agent-pattern-labs/iso-redact": "^0.1.1",
    "@agent-pattern-labs/iso-trace": "^0.5.1",
    "playwright": "^1.58.1"
  },
  "devDependencies": {
    "@agent-pattern-labs/agentmd": "^0.3.1",
    "@agent-pattern-labs/iso": "^0.3.2",
    "@agent-pattern-labs/iso-eval": "^0.4.1",
    "@agent-pattern-labs/iso-harness": "^0.8.1",
    "@agent-pattern-labs/iso-route": "^0.6.1"
  }
}
